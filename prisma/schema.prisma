generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH MODELS (Auth.js v5 compatible + custom fields)
// ============================================================

enum UserRole {
  USER
  ADMIN
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  emailVerified     DateTime?
  hashedPassword    String?
  image             String?
  role              UserRole  @default(USER)
  preferredLocale   String    @default("he")
  notificationPrefs Json      @default("{\"emailNotifications\":true,\"inAppNotifications\":true}")
  isActive          Boolean   @default(true)
  companyName       String?
  idNumber          String?
  address           String?
  phone             String?
  // PRIV-02: TOTP MFA fields for admin accounts
  mfaSecret         String? // TOTP secret (encrypted base32)
  mfaEnabled        Boolean   @default(false)
  mfaVerifiedAt     DateTime? // When MFA was first verified/enabled
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  documents         Document[]
  importedContracts ImportedContract[]
  documentShares    DocumentShare[]
  auditLogs         AuditLog[]
  subscriptions     Subscription[]
  payments          Payment[]
  notifications     Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// TEMPLATE SYSTEM
// ============================================================

model Category {
  id             String   @id @default(cuid())
  slug           String   @unique
  nameHe         String
  nameAr         String
  nameEn         String
  nameRu         String
  descHe         String   @default("")
  descAr         String   @default("")
  descEn         String   @default("")
  descRu         String   @default("")
  icon           String?  // Lucide icon name, e.g. "Home", "Car", "Briefcase"
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  requiresWetInk Boolean  @default(false) // ESIG-05: wet-ink-only categories
  legalRules     Json? // LREG: per-category legal constraints
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  templates Template[]

  @@index([isActive])
  @@map("categories")
}

model Template {
  id         String   @id @default(cuid())
  slug       String   @unique
  nameHe     String
  nameAr     String
  nameEn     String
  nameRu     String
  descHe     String   @default("")
  descAr     String   @default("")
  descEn     String   @default("")
  descRu     String   @default("")
  categoryId String
  definition Json
  version    Int      @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category  Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  snapshots TemplateSnapshot[]
  documents Document[]

  @@index([categoryId])
  @@index([isActive])
  @@map("templates")
}

model TemplateSnapshot {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  definition Json
  changeNote String   @default("")
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_snapshots")
}

// ============================================================
// DOCUMENTS (User-Generated Contracts)
// ============================================================

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE // ESIG-12: awaiting all signatories
  PUBLISHED
  SIGNED
  ARCHIVED
}

model Document {
  id              String         @id @default(cuid())
  title           String
  userId          String
  templateId      String
  templateVersion Int
  wizardData      Json
  renderedBody    String?        @db.Text
  pdfUrl          String?
  documentHash    String? // ESIG-03: SHA-256 hash of finalized content
  status          DocumentStatus @default(DRAFT)
  locale          String         @default("he")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?
  signedAt        DateTime? // ESIG: when all signatures completed

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template          @relation(fields: [templateId], references: [id])
  signatories Signatory[]
  signatures  SignatureRecord[]
  shares      DocumentShare[]
  comments    DocumentComment[]

  @@index([userId])
  @@index([userId, status])
  @@index([templateId])
  @@index([createdAt])
  @@map("documents")
}

// ============================================================
// IMPORTED CONTRACTS (For AI Review & Analysis)
// ============================================================

model ImportedContract {
  id             String   @id @default(cuid())
  userId         String
  title          String
  blobUrl        String
  extractedText  String?  @db.Text
  analysisResult Json? // Stores structured risk flags & summary
  locale         String   @default("he")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("imported_contracts")
}

// ============================================================
// ELECTRONIC SIGNATURES (ESIG)
// ============================================================

enum SignatoryRole {
  INITIATOR
  COUNTER_PARTY
}

model Signatory {
  id             String        @id @default(cuid())
  documentId     String
  name           String
  email          String
  role           SignatoryRole
  otpHash        String? // ESIG-07: hashed OTP for email verification
  otpExpiresAt   DateTime?
  verifiedAt     DateTime? // OTP verified timestamp
  signedAt       DateTime? // Signing completed timestamp
  signatureImage String?       @db.Text // ESIG-08: base64 PNG drawn signature
  ip             String? // ESIG-06: audit trail
  userAgent      String?

  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatures SignatureRecord[]

  @@index([documentId])
  @@index([email])
  @@map("signatories")
}

model SignatureRecord {
  id            String   @id @default(cuid())
  documentId    String
  signatoryId   String
  hashAlgorithm String   @default("SHA-256") // ESIG-03
  documentHash  String // SHA-256 of document content
  signature     String   @db.Text // Encrypted hash (Base64)
  timestamp     DateTime @default(now()) // ESIG-04: signing timestamp
  certificate   String?  @db.Text // Certificate chain (placeholder for PAdES-LTA)

  document  Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatory Signatory @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("signature_records")
}

// ============================================================
// DOCUMENT SHARING (DOCM-06)
// ============================================================

enum DocumentSharePermission {
  VIEW
  COMMENT
}

model DocumentShare {
  id         String                  @id @default(cuid())
  documentId String
  token      String                  @unique @default(cuid())
  expiresAt  DateTime
  permission DocumentSharePermission @default(VIEW)
  createdAt  DateTime                @default(now())
  createdBy  String // userId who created the share link

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([documentId])
  @@map("document_shares")
}

model DocumentComment {
  id          String   @id @default(cuid())
  documentId  String
  authorName  String
  authorEmail String?
  content     String   @db.Text
  quote       String?  @db.Text
  position    String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_comments")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String? // PRIV-05: enhanced audit trail
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// PAYMENTS & INVOICING (PAYM)
// ============================================================

model Plan {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameHe        String
  nameAr        String
  nameEn        String
  nameRu        String
  priceIls      Int // price in agorot (ILS × 100)
  documentLimit Int      @default(-1) // max documents per subscription period; -1 = unlimited
  features      Json // array of feature keys
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
  @@map("plans")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([userId, status, endDate])
  @@map("subscriptions")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PENDING_CLEARANCE // PAYM-06: awaiting ITA clearance
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  subscriptionId      String?
  documentId          String? // For pay-per-document purchases
  amount              Int // in agorot (ILS × 100)
  vatAmount           Int // PAYM-09: 17% VAT in agorot
  currency            String        @default("ILS")
  status              PaymentStatus @default(PENDING)
  installments        Int           @default(1) // PAYM-02: Tashlumim
  gatewayRef          String? // external payment gateway reference
  itaAllocationNumber String? // PAYM-04: 9-digit ITA CTC number
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoices     Invoice[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([documentId])
  @@map("payments")
}

enum InvoiceType {
  TAX_INVOICE // חשבונית מס
  TAX_RECEIPT // חשבונית מס קבלה (PAYM-08)
  CREDIT_INVOICE // חשבונית זיכוי (PAYM-10)
}

model Invoice {
  id                  String      @id @default(cuid())
  paymentId           String
  invoiceNumber       String      @unique
  type                InvoiceType @default(TAX_RECEIPT)
  amount              Int // in agorot
  vatAmount           Int
  itaAllocationNumber String? // PAYM-07: embedded on PDF
  pdfUrl              String?
  createdAt           DateTime    @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("invoices")
}

// ============================================================
// INVOICE SEQUENTIAL NUMBERING (Israeli tax law compliance)
// ============================================================

model InvoiceCounter {
  year    Int @id
  lastSeq Int @default(0)

  @@map("invoice_counters")
}

// ============================================================
// WEBHOOK IDEMPOTENCY (prevents duplicate processing)
// ============================================================

model ProcessedWebhookEvent {
  id          String   @id // Stripe event ID or legacy event identifier
  processedAt DateTime @default(now())

  @@index([processedAt])
  @@map("processed_webhook_events")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  SIGNATURE_REQUESTED
  SIGNATURE_COMPLETED
  SIGNATURE_EXPIRED
  DOCUMENT_SHARED
  DOCUMENT_COMMENT
  ANALYSIS_COMPLETE
  PAYMENT_RECEIPT
  SUBSCRIPTION_EXPIRING
  USAGE_LIMIT_APPROACHING
  ADMIN_TEMPLATE_UPDATED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  titleKey  String
  bodyKey   String
  params    Json?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// SITE SETTINGS (Key-Value Store for Branding & Config)
// ============================================================

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ============================================================
// AI & LLM SETTINGS
// ============================================================

model LlmSetting {
  id        String   @id @default(cuid())
  provider  String   @unique // 'openai', 'claude', 'gemini'
  apiKey    String // Encrypted via field-cipher (AES-256-GCM) in llm-settings.ts
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("llm_settings")
}
