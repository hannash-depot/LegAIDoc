# Database
DATABASE_URL="postgresql://user:password@localhost:5432/legaidoc?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Admin access — comma-separated list of email addresses granted admin access
# e.g. ADMIN_EMAILS="alice@example.com,bob@example.com"
ADMIN_EMAILS=""

# PDF generation — Chromium binary for serverless (production only)
# Override the default GitHub release URL if you host the tar yourself
# (useful to avoid GitHub rate-limits on Vercel cold-starts)
CHROMIUM_PACK_URL=""
