# Database
DATABASE_URL="postgresql://legaidoc:legaidoc@localhost:5432/legaidoc?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="he"

# PDF Generation
PDF_STORAGE_DIR="./storage/pdfs"

# Payments (Stripe)
PAYMENT_PROVIDER="stripe"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
DOCUMENT_PRICE_ILS="4900"
PAYMENT_WEBHOOK_SECRET="your_webhook_secret_here"

# Electronic Signatures (required in production when ESIG is enabled)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents with \n for line breaks
ESIG_RSA_PRIVATE_KEY=""
ESIG_RSA_PUBLIC_KEY=""
ESIG_OTP_EXPIRY_MINUTES="15"

# Field-Level Encryption (required — generate with: openssl rand -hex 32)
FIELD_ENCRYPTION_KEY=""

# AI Providers (optional — can also be provided via the UI)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""

# Feature Flags
NEXT_PUBLIC_FEATURE_ESIG="false"
NEXT_PUBLIC_FEATURE_AI_IMPORT="false"
NEXT_PUBLIC_FEATURE_PAYMENTS="false"
NEXT_PUBLIC_FEATURE_EMAILS="false"

# Email
RESEND_API_KEY=""
EMAIL_FROM="LegAIDoc <noreply@legaidoc.co.il>"

# Error Tracking (Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Business Details (required on invoices per Israeli tax law)
BUSINESS_NAME="LegAIDoc"
BUSINESS_VAT_NUMBER=""
BUSINESS_ADDRESS=""
BUSINESS_PHONE=""
BUSINESS_EMAIL="support@legaidoc.co.il"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_AUTHENTICATED="100"
RATE_LIMIT_MAX_UNAUTHENTICATED="20"

# Upstash Redis (required in production for distributed rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
