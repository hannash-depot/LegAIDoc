# Database
DATABASE_URL="postgresql://user:password@localhost:5432/legaidoc?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_TERMS_VERSION="2026-02-25"
NEXT_PUBLIC_PRIVACY_VERSION="2026-02-25"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Resend Email (https://resend.com/api-keys)
RESEND_API_KEY=""
EMAIL_FROM="LegAIDoc <noreply@yourdomain.com>"

# Optional alert webhook for critical API errors
ALERT_WEBHOOK_URL=""

# Required for /api/setup-admin endpoint access
SETUP_ADMIN_TOKEN=""
