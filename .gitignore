# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production.local
.env.development.local

# storage (generated PDFs)
/storage

# local caches (persistent LLM parse cache, etc.)
/.cache

# uploaded files
/public/uploads/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs & diagnostic dumps
*.log
ts_errors.txt
lint_*.txt
current_tsc.log

# tooling artifacts
/test-results
/playwright-report
